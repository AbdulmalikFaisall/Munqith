# Munqith Environment Configuration
# Copy to .env and customize for your environment

# ===== DATABASE CONFIGURATION =====
# Database URL (for direct connection string)
DATABASE_URL=postgresql://munqith:munqith@localhost:5432/munqith

# Or use individual components (docker-compose uses these)
DB_NAME=munqith
DB_USER=munqith
DB_PASSWORD=munqith_change_in_production
POSTGRES_PORT=5432

# ===== APPLICATION CONFIGURATION =====
# Environment: development, staging, production
ENV=development

# API Port
API_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== SECURITY (Production Only) =====
# Change these in production!
# SECRET_KEY=your-secret-key-here-change-in-production
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== OPTIONAL FEATURES =====
# Enable analytics module (Sprint 11)
# ANALYTICS_ENABLED=true

# Debug mode (never enabled in production)
DEBUG=false
